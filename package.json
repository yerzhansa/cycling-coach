{
  "name": "enduragent-workspace",
  "version": "0.0.0-private",
  "private": true,
  "description": "Workspace coordinator for the enduragent monorepo (Core + sport packages + binary packages).",
  "type": "module",
  "scripts": {
    "dev": "tsx --env-file=.env packages/cycling-coach/src/index.ts",
    "setup": "tsx --env-file=.env packages/cycling-coach/src/index.ts setup",
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint packages/",
    "fmt": "oxfmt packages/",
    "fmt:check": "oxfmt --check packages/",
    "check": "pnpm -r build && oxlint packages/"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.69",
    "@ai-sdk/google": "^3.0.63",
    "@ai-sdk/openai": "^3.0.52",
    "@ai-sdk/provider": "^3.0.9",
    "@ai-sdk/provider-utils": "^4.0.24",
    "@clack/prompts": "^1.2.0",
    "@enduragent/core": "workspace:*",
    "@enduragent/sport-cycling": "workspace:*",
    "@mariozechner/pi-ai": "0.67.6",
    "ai": "^6.0.158",
    "grammy": "^1.42.0",
    "intervals-icu-api": "^0.1.2",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@types/node": "^25.6.0",
    "msw": "^2.13.3",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.6.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@google/genai",
      "esbuild",
      "msw",
      "protobufjs"
    ]
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yerzhansa/cycling-coach.git"
  }
}
